{
  "components": [
    {
      "name": "Button",
      "props": {
        "variant": "default | destructive | outline | secondary | ghost | link",
        "size": "default | sm | lg | icon",
        "asChild": "boolean",
        "disabled": "boolean",
        "onClick": "() => void"
      },
      "usage": "<Button variant=\"default\" size=\"default\" onClick={handleClick}>Click me</Button>",
      "dos": [
        "Use appropriate variant for context (destructive for delete actions)",
        "Include onClick handlers for interactive buttons",
        "Use disabled prop when button should not be clickable"
      ],
      "donts": [
        "Don't nest buttons inside other buttons",
        "Don't use buttons for navigation (use links instead)",
        "Don't forget to add onClick handlers"
      ]
    },
    {
      "name": "Card",
      "props": {
        "className": "string"
      },
      "usage": "<Card><CardHeader><CardTitle>Title</CardTitle></CardHeader><CardContent>Content</CardContent></Card>",
      "dos": [
        "Use Card for grouping related content",
        "Combine with CardHeader, CardTitle, CardContent for structure",
        "Add appropriate padding and spacing"
      ],
      "donts": [
        "Don't use Card without content",
        "Don't nest cards excessively (max 2 levels)",
        "Don't forget hover effects for interactive cards"
      ]
    },
    {
      "name": "CardHeader",
      "props": {
        "className": "string"
      },
      "usage": "<CardHeader><CardTitle>Title</CardTitle><CardDescription>Description</CardDescription></CardHeader>",
      "dos": [
        "Use inside Card component",
        "Include CardTitle and optionally CardDescription",
        "Keep header content concise"
      ],
      "donts": [
        "Don't use without a Card parent",
        "Don't include body content in header"
      ]
    },
    {
      "name": "CardTitle",
      "props": {
        "className": "string"
      },
      "usage": "<CardTitle>Dashboard Overview</CardTitle>",
      "dos": [
        "Use inside CardHeader",
        "Keep titles short and descriptive",
        "Use appropriate text size (default is text-2xl)"
      ],
      "donts": [
        "Don't use multiple CardTitle in same CardHeader",
        "Don't use overly long titles"
      ]
    },
    {
      "name": "CardDescription",
      "props": {
        "className": "string"
      },
      "usage": "<CardDescription>View your analytics and metrics</CardDescription>",
      "dos": [
        "Use inside CardHeader after CardTitle",
        "Provide helpful context about card content",
        "Keep descriptions brief (1-2 sentences)"
      ],
      "donts": [
        "Don't duplicate title information",
        "Don't use without CardTitle"
      ]
    },
    {
      "name": "CardContent",
      "props": {
        "className": "string"
      },
      "usage": "<CardContent><p>Your main content here</p></CardContent>",
      "dos": [
        "Use inside Card for main content",
        "Include all body content and interactive elements",
        "Add appropriate padding (default p-6)"
      ],
      "donts": [
        "Don't use without Card parent",
        "Don't include header or footer content"
      ]
    },
    {
      "name": "CardFooter",
      "props": {
        "className": "string"
      },
      "usage": "<CardFooter><Button>Action</Button></CardFooter>",
      "dos": [
        "Use inside Card for actions or metadata",
        "Include action buttons or summary information",
        "Align items appropriately (flex layout)"
      ],
      "donts": [
        "Don't use without Card parent",
        "Don't include body content in footer"
      ]
    },
    {
      "name": "Input",
      "props": {
        "type": "text | email | password | number | search | tel | url | date",
        "placeholder": "string",
        "value": "string",
        "onChange": "(e: React.ChangeEvent<HTMLInputElement>) => void",
        "disabled": "boolean",
        "required": "boolean"
      },
      "usage": "<Input type=\"text\" placeholder=\"Enter name\" value={name} onChange={(e) => setName(e.target.value)} />",
      "dos": [
        "Always include onChange handler for controlled inputs",
        "Use appropriate type for input (email, password, etc.)",
        "Include placeholder text for better UX",
        "Pair with Label for accessibility"
      ],
      "donts": [
        "Don't use without onChange handler",
        "Don't forget to set value prop for controlled inputs",
        "Don't omit labels for accessibility"
      ]
    },
    {
      "name": "Label",
      "props": {
        "htmlFor": "string",
        "className": "string"
      },
      "usage": "<Label htmlFor=\"email\">Email Address</Label><Input id=\"email\" type=\"email\" />",
      "dos": [
        "Always associate with input using htmlFor and id",
        "Use descriptive label text",
        "Place label before or above input"
      ],
      "donts": [
        "Don't use without htmlFor attribute",
        "Don't use generic label text like 'Input'",
        "Don't forget to match id on input element"
      ]
    },
    {
      "name": "Badge",
      "props": {
        "variant": "default | secondary | destructive | outline",
        "className": "string"
      },
      "usage": "<Badge variant=\"default\">New</Badge>",
      "dos": [
        "Use for status indicators, tags, or counts",
        "Choose appropriate variant for context",
        "Keep text short (1-3 words)"
      ],
      "donts": [
        "Don't use for interactive elements (use Button)",
        "Don't use overly long text",
        "Don't use as main content containers"
      ]
    },
    {
      "name": "Avatar",
      "props": {
        "className": "string"
      },
      "usage": "<Avatar><AvatarImage src={url} alt={name} /><AvatarFallback>{initials}</AvatarFallback></Avatar>",
      "dos": [
        "Always include both AvatarImage and AvatarFallback",
        "Use appropriate alt text for accessibility",
        "Use initials or icon in fallback"
      ],
      "donts": [
        "Don't use without fallback",
        "Don't forget alt text on AvatarImage",
        "Don't use for non-profile images"
      ]
    },
    {
      "name": "AvatarImage",
      "props": {
        "src": "string",
        "alt": "string"
      },
      "usage": "<AvatarImage src=\"/avatars/user.jpg\" alt=\"John Doe\" />",
      "dos": [
        "Use inside Avatar component",
        "Always provide alt text",
        "Use appropriate image URLs"
      ],
      "donts": [
        "Don't use without Avatar parent",
        "Don't omit alt attribute",
        "Don't use broken image URLs"
      ]
    },
    {
      "name": "AvatarFallback",
      "props": {
        "className": "string"
      },
      "usage": "<AvatarFallback>JD</AvatarFallback>",
      "dos": [
        "Use inside Avatar component",
        "Display user initials or icon",
        "Keep text short (1-2 characters)"
      ],
      "donts": [
        "Don't use without Avatar parent",
        "Don't use long text strings",
        "Don't leave empty"
      ]
    },
    {
      "name": "Table",
      "props": {
        "className": "string"
      },
      "usage": "<Table><TableHeader>...</TableHeader><TableBody>...</TableBody></Table>",
      "dos": [
        "Use for tabular data",
        "Include TableHeader and TableBody",
        "Add appropriate column headers"
      ],
      "donts": [
        "Don't use for layout purposes",
        "Don't forget table headers",
        "Don't nest tables unnecessarily"
      ]
    },
    {
      "name": "TableHeader",
      "props": {
        "className": "string"
      },
      "usage": "<TableHeader><TableRow><TableHead>Name</TableHead><TableHead>Email</TableHead></TableRow></TableHeader>",
      "dos": [
        "Use inside Table",
        "Include TableRow with TableHead cells",
        "Define all column headers"
      ],
      "donts": [
        "Don't use without Table parent",
        "Don't use TableCell in header (use TableHead)"
      ]
    },
    {
      "name": "TableBody",
      "props": {
        "className": "string"
      },
      "usage": "<TableBody><TableRow><TableCell>John</TableCell><TableCell>john@example.com</TableCell></TableRow></TableBody>",
      "dos": [
        "Use inside Table",
        "Include TableRow elements with TableCell",
        "Match cell count with header count"
      ],
      "donts": [
        "Don't use without Table parent",
        "Don't mix up cell and header cells"
      ]
    },
    {
      "name": "TableRow",
      "props": {
        "className": "string"
      },
      "usage": "<TableRow><TableCell>Data 1</TableCell><TableCell>Data 2</TableCell></TableRow>",
      "dos": [
        "Use inside TableHeader or TableBody",
        "Include appropriate cells (TableHead or TableCell)",
        "Add hover effects for better UX"
      ],
      "donts": [
        "Don't use without Table parent",
        "Don't leave rows empty"
      ]
    },
    {
      "name": "TableHead",
      "props": {
        "className": "string"
      },
      "usage": "<TableHead>Column Name</TableHead>",
      "dos": [
        "Use inside TableRow in TableHeader",
        "Provide descriptive column names",
        "Keep header text concise"
      ],
      "donts": [
        "Don't use in TableBody (use TableCell)",
        "Don't use empty headers"
      ]
    },
    {
      "name": "TableCell",
      "props": {
        "className": "string"
      },
      "usage": "<TableCell>Cell content</TableCell>",
      "dos": [
        "Use inside TableRow in TableBody",
        "Display data corresponding to column headers",
        "Format data appropriately"
      ],
      "donts": [
        "Don't use in TableHeader (use TableHead)",
        "Don't leave cells empty unless intentional"
      ]
    },
    {
      "name": "Separator",
      "props": {
        "orientation": "horizontal | vertical",
        "decorative": "boolean",
        "className": "string"
      },
      "usage": "<Separator orientation=\"horizontal\" className=\"my-4\" />",
      "dos": [
        "Use to separate content sections",
        "Set appropriate orientation",
        "Add margin for spacing"
      ],
      "donts": [
        "Don't overuse (creates visual clutter)",
        "Don't use instead of proper spacing"
      ]
    }
  ]
}
